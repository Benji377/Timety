<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#7C3AED" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <!-- Opaque fill between the purple side rails; the old translucent overlay left
                 the row solid purple and made the text unreadable -->
            <solid android:color="#FBF8FF" />
        </shape>
    </item>
</layer-list>
